#!/bin/bash
set -e

setup_user_and_dirs() {
    if ! getent group rmpd >/dev/null; then
        addgroup --system rmpd
    fi

    if ! getent passwd rmpd >/dev/null; then
        adduser --system \
            --ingroup rmpd \
            --home /var/lib/rmpd \
            --no-create-home \
            --shell /usr/sbin/nologin \
            rmpd
    fi

    if getent group audio >/dev/null; then
        adduser rmpd audio >/dev/null || true
    fi

    mkdir -p /etc/rmpd
    mkdir -p /var/lib/rmpd/music
    mkdir -p /var/lib/rmpd/playlists
    mkdir -p /var/lib/rmpd/state

    chown rmpd:rmpd /var/lib/rmpd /var/lib/rmpd/music /var/lib/rmpd/playlists /var/lib/rmpd/state
    chmod 755 /var/lib/rmpd /var/lib/rmpd/music /var/lib/rmpd/playlists /var/lib/rmpd/state
}

case "$1" in
    configure)
        setup_user_and_dirs
        ;;
esac

# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	# The following line should be removed in trixie or trixie+1
	deb-systemd-helper unmask 'rmpd.service' >/dev/null || true

	# was-enabled defaults to true, so new installations run enable.
	if deb-systemd-helper --quiet was-enabled 'rmpd.service'; then
		# Enables the unit on first installation, creates new
		# symlinks on upgrades if the unit file has changed.
		deb-systemd-helper enable 'rmpd.service' >/dev/null || true
	else
		# Update the statefile to add new symlinks (if any), which need to be
		# cleaned up on purge. Also remove old symlinks.
		deb-systemd-helper update-state 'rmpd.service' >/dev/null || true
	fi
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.24.2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -d /run/systemd/system ]; then
		systemctl --system daemon-reload >/dev/null || true
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		deb-systemd-invoke $_dh_action 'rmpd.service' >/dev/null || true
	fi
fi
# End automatically added section


exit 0